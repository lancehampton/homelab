(cloudflare) {
  tls {
    dns cloudflare {$CLOUDFLARE_API_TOKEN}
    resolvers 1.1.1.1
  }
}

birdnet.{$CLOUDFLARE_CNAME} {
  reverse_proxy http://host.docker.internal:8080
  import cloudflare
}

home.{$CLOUDFLARE_CNAME} {
  reverse_proxy http://host.docker.internal:3080
  import cloudflare
}

readeck.{$CLOUDFLARE_CNAME} {
  reverse_proxy http://host.docker.internal:8000
  import cloudflare
}

homeassistant.{$CLOUDFLARE_CNAME} {
  reverse_proxy http://host.docker.internal:8123
  import cloudflare
}

dockhand.{$CLOUDFLARE_CNAME} {
  reverse_proxy http://host.docker.internal:3000
  import cloudflare
}

cockpit.{$CLOUDFLARE_CNAME} {
  reverse_proxy https://host.docker.internal:9090 {
    transport http {
      tls_insecure_skip_verify
    }
  }
  import cloudflare
}
